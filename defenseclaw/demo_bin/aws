#!/usr/bin/env python3
"""AWS CLI simulation: deterministic output and no AWS transport."""

from __future__ import annotations

import json
import sys


def main() -> int:
    arguments = sys.argv[1:]
    if arguments[:2] == ["s3api", "list-buckets"]:
        print(json.dumps({"Buckets": [{"Name": "demo-protected-bucket"}], "simulated": True}))
        return 0
    if arguments[:2] in (["s3api", "delete-bucket"], ["s3", "rb"]):
        print(
            "FAKE AWS SAFETY NET: bucket deletion was not sent to AWS.",
            file=sys.stderr,
        )
        return 3
    print(f"FAKE AWS: unsupported simulation command: {' '.join(arguments)}", file=sys.stderr)
    return 64


if __name__ == "__main__":
    raise SystemExit(main())
